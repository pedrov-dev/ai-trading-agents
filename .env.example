# Safe local dry-run defaults
KRAKEN_EXECUTION_DRY_RUN=true
KRAKEN_LIVE_ENABLED=false
KRAKEN_ORDER_TYPE=market
KRAKEN_CLI_TIMEOUT_SECONDS=15
KRAKEN_CLI_MAX_RETRIES=2
KRAKEN_AUDIT_LOG_PATH=artifacts/orders_audit.jsonl

# Optional: override the CLI executable path
# KRAKEN_CLI_EXECUTABLE=kraken-cli

# Optional external-backed storage / database settings
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_trading_agents
# CF_R2_BUCKET=your-bucket
# CF_R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# CF_R2_ACCESS_KEY=...
# CF_R2_SECRET_KEY=...
