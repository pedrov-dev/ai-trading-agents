# Kraken trading defaults
TRADING_MODE=paper
IDENTITY_LAYER=none
KRAKEN_EXECUTION_DRY_RUN=false
KRAKEN_LIVE_ENABLED=true
KRAKEN_VALIDATE_ONLY=true
KRAKEN_ORDER_TYPE=market
KRAKEN_CLI_TIMEOUT_SECONDS=15
KRAKEN_CLI_MAX_RETRIES=2
KRAKEN_AUDIT_LOG_PATH=artifacts/orders_audit.jsonl

# Optional: override the CLI executable path
# KRAKEN_CLI_EXECUTABLE=kraken-cli
# KRAKEN_API_KEY=...                # required for both TRADING_MODE=paper and TRADING_MODE=live
# KRAKEN_API_SECRET=...             # required for both TRADING_MODE=paper and TRADING_MODE=live
# KRAKEN_CLI_ALLOW_LIVE_SUBMIT=true     # required when TRADING_MODE=live

# Optional shared Sepolia ERC-8004 identity layer
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_CHAIN_ID=11155111
AGENT_REGISTRY_ADDRESS=0x97b07dDc405B0c28B17559aFFE63BdB3632d0ca3
HACKATHON_VAULT_ADDRESS=0x0E7CD8ef9743FEcf94f9103033a044caBD45fC90
RISK_ROUTER_ADDRESS=0xd6A6952545FF6E6E6681c2d15C59f9EB8F40FdBC
REPUTATION_REGISTRY_ADDRESS=0x423a9904e39537a9997fbaF0f220d79D7d545763
VALIDATION_REGISTRY_ADDRESS=0x92bF63E5C7Ac6980f237a7164Ab413BE226187F1
# PRIVATE_KEY=0x...                   # operator wallet: owns the agent NFT and pays gas
# AGENT_WALLET_PRIVATE_KEY=0x...      # agent wallet: signs RiskRouter trade intents
# AGENT_ID=123                        # persist the on-chain id after first registration
AGENT_DISPLAY_NAME=AI Trading Agent Demo
AGENT_STRATEGY_NAME=simple_event_driven
# AGENT_OWNER=pedrov-dev
# AGENT_DESCRIPTION=Event-driven crypto strategy for the ERC-8004 challenge
# AGENT_URI=https://github.com/pedrov-dev/ai-trading-agents
# AGENT_CAPABILITIES=trading,eip712-signing,checkpoints

# Required external-backed storage settings (the runtime no longer falls back to local/in-memory storage)
# POSTGRES_ENABLED=true
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_trading_agents
# CF_R2_BUCKET=your-bucket
# CF_R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# CF_R2_ACCESS_KEY=...
# CF_R2_SECRET_KEY=...
# CF_R2_REGION=auto
